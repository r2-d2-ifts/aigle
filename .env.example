# ===== Jira (read-only) =====
# Personal Access Token from your Jira instance.
JIRA_SERVER=https://jira.example.com
JIRA_LOGIN=your-jira-username
JIRA_API_TOKEN=replace-with-your-jira-pat
JIRA_PROJECT=PROJ

# ===== Groq (LLM provider) =====
# Get a key at https://console.groq.com/keys
# Default model used in code: llama-3.3-70b-versatile
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Supabase (Postgres + REST) =====
# Project Settings > API in https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SECRET_KEY=sb_secret_xxx
SUPABASE_JWT_SECRET=your-jwt-secret

# ===== Postgres (direct + pooled) =====
POSTGRES_DATABASE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
POSTGRES_HOST=db.your-project-ref.supabase.co
POSTGRES_URL=postgres://postgres.your-project-ref:password@host:6543/postgres?sslmode=require
POSTGRES_PRISMA_URL=postgres://postgres.your-project-ref:password@host:6543/postgres?sslmode=require&pgbouncer=true
POSTGRES_URL_NON_POOLING=postgres://postgres.your-project-ref:password@host:5432/postgres?sslmode=require
